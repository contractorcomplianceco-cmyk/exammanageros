# ExamManagerOS — environment variables (no secrets in repo)
# Copy to server: /home/ubuntu/projects/scripts/exammanageros.env

# API
NODE_ENV=production
PORT=5031

# Database
DATABASE_URL=postgresql://exammanageros_app:CHANGE_ME@127.0.0.1:5432/exammanageros

# Auth
SESSION_SECRET=CHANGE_ME_LONG_RANDOM_STRING

# Bootstrap operators (set once, then remove or rotate)
BOOTSTRAP_ROSE_EMAIL=rose@contractorcomplianceauthority.com
BOOTSTRAP_ROSE_PASSWORD=CHANGE_ME
BOOTSTRAP_CARMEN_EMAIL=carmen@contractorcomplianceauthority.com
BOOTSTRAP_CARMEN_PASSWORD=CHANGE_ME

# Public URL (uptime monitoring)
EXAMMANAGEROS_PUBLIC_URL=https://exams.cagteam.net
EXAMMANAGEROS_LOCAL_URL=http://127.0.0.1:5030/
EXAMMANAGEROS_CHECK_PUBLIC=1

# Integration feature flags (default off)
ZOHO_SYNC_ENABLED=0
COMPLIANCE_CONNECT_ENABLED=0
DOC_COLLECT_ENABLED=0
WORKDRIVE_ENABLED=0

# Integration credentials (server-only, when enabled)
# ZOHO_CLIENT_ID=
# ZOHO_CLIENT_SECRET=
# ZOHO_REFRESH_TOKEN=
# COMPLIANCE_CONNECT_API_URL=http://127.0.0.1:3001
# COMPLIANCE_CONNECT_SERVICE_TOKEN=
# DOCS_COLLECT_API_URL=
# DOCS_COLLECT_SERVICE_TOKEN=

# Notifications
NOTIFICATION_EMAIL_ENABLED=0
NOTIFICATION_EMAIL_TO=
